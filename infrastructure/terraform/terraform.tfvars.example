aws_region        = "us-east-1"
project_name      = "food-delivery"
environment       = "dev"
eks_cluster_name  = "eks-food-delivery-dev"
node_desired_size = 2
node_min_size     = 1
node_max_size     = 3
node_instance_type = "t3.medium"

ecr_repository_names = [
  "order-service",
  "restaurant-service",
  "delivery-service"
]

tags = {
  project = "food-delivery"
  env     = "dev"
  owner   = "devops-team"
}
